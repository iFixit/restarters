# Application Configuration
APP_NAME=Restarters.net
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8050
APP_LOGO=fixitclinic
APP_SHOW_BRANCH=true
APP_SHOW_COMMUNITY_TEST=false

# Feature Flags
FEATURE_WORKBENCH_INTEGRATION=false
FEATURE__WIKI_INTEGRATION=false
FEATURE__DISCOURSE_INTEGRATION=false

# Logging
LOG_CHANNEL=stack

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=restarters-db
DB_PORT=3307
DB_DATABASE=restarters_db_test
DB_USERNAME=restarters
DB_PASSWORD=s3cr3t

# Session Configuration
SESSION_DRIVER=database
SESSION_COOKIE=restarters_session
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=
SESSION_LIFETIME=10080
SESSION_TABLE=laravel_sessions

# Cache Configuration
CACHE_DRIVER=file
QUEUE_CONNECTION=database

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=restarters_
REDIS_CLIENT=phpredis

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=host.docker.internal
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

