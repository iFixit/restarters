# Docker-specific environment settings
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8001

# Docker Database
DB_CONNECTION=mysql
DB_HOST=restarters_db
DB_PORT=3306
DB_DATABASE=restarters_db_test

# Docker Services
MAIL_HOST=restarters_mailhog
MAIL_PORT=1025
MAIL_FROM_ADDRESS=dev@restarters.net
MAIL_FROM_NAME=Restarters.net

# Docker Discourse Integration
FEATURE__DISCOURSE_INTEGRATION=true
DISCOURSE_URL=http://www.example.com:8003
DISCOURSE_APIUSER=someuser
DISCOURSE_APIKEY=
DISCOURSE_SECRET=mustbetencharacters 